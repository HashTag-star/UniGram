EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google OAuth — Web client ID from Google Cloud Console (used by GoogleSignin).
# Required only for native Google sign-in; browser fallback works without it.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com

# TURN server — required for live streaming on campus/mobile networks with strict NAT.
# Providers: Metered (metered.ca), Xirsys, Twilio NTS, or self-hosted coturn.
EXPO_PUBLIC_TURN_URL=turn:your-turn-server.com:3478
EXPO_PUBLIC_TURNS_URL=turns:your-turn-server.com:5349
EXPO_PUBLIC_TURN_USERNAME=your-turn-username
EXPO_PUBLIC_TURN_CREDENTIAL=your-turn-credential

# Paystack — secret key lives as a Supabase Edge Function secret, NOT an Expo env var.
# Set it with: npx supabase secrets set PAYSTACK_SECRET_KEY=sk_live_xxx
# For testing: npx supabase secrets set PAYSTACK_SECRET_KEY=sk_test_xxx
# Webhook URL to register in your Paystack dashboard (Settings → Webhooks):
#   https://rcvzcbfmstgwzrolnhvy.supabase.co/functions/v1/paystack-webhook
