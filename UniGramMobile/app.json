{
  "expo": {
    "name": "UniGram",
    "slug": "unigram-mobile-v2",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "unigram",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05050a"
    },
    "intentFilters": [
      {
        "action": "VIEW",
        "autoVerify": true,
        "data": [
          {
            "scheme": "unigram"
          }
        ],
        "category": [
          "BROWSABLE",
          "DEFAULT"
        ]
      }
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unigram.mobile",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "NSCameraUsageDescription": "UniGram needs camera access to take photos and videos for posts and reels.",
        "NSMicrophoneUsageDescription": "UniGram needs microphone access to record audio for videos and reels.",
        "NSPhotoLibraryUsageDescription": "UniGram needs access to your photo library to share photos and videos.",
        "NSPhotoLibraryAddUsageDescription": "UniGram needs permission to save media to your photo library.",
        "NSLocationWhenInUseUsageDescription": "UniGram uses your location to tag posts and show nearby marketplace items.",
        "NSUserNotificationsUsageDescription": "UniGram sends notifications for likes, comments, messages, and campus events.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05050a"
      },
      "package": "com.unigram.mobile",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "adjustResize",
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "predictiveBackGestureEnabled": false,
      "statusBar": {
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-media-library",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/notification_alert.wav"
          ]
        }
      ],
      "expo-image-picker",
      "expo-video",
      "expo-audio",
      "expo-asset",
      "react-native-webrtc",
      [
        "expo-build-properties",
        {
          "android": {
            "minifyEnabled": true,
            "shrinkResources": true,
            "extraGradleProps": {
              "enablePngCrunch": "true"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b08e2c74-68d1-4e72-94ac-a92750902d6a"
      }
    },
    "owner": "heis_hashtag",
    "updates": {
      "url": "https://u.expo.dev/b08e2c74-68d1-4e72-94ac-a92750902d6a"
    }
  }
}
