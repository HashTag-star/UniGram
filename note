CREATE OR REPLACE FUNCTION match_contacts(p_emails text[])
  RETURNS TABLE(...profile columns...) SECURITY DEFINER AS $$
    SELECT p.id, p.username, p.full_name, p.avatar_url,
           p.is_verified, p.verification_type, p.university,
           p.major, p.followers_count
    FROM auth.users u
    JOIN profiles p ON p.id = u.id
    WHERE lower(u.email) = ANY(p_emails)
      AND p.id != auth.uid()
      AND p.is_banned = false
      AND p.username IS NOT NULL;
  $$ LANGUAGE sql;